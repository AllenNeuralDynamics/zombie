{
  "name": "zombie-mosaic",
  "version": "0.1.0",
  "description": "ZOMBIE data explorer — Mosaic/DuckDB-WASM frontend",
  "type": "module",
  "scripts": {
    "start": "concurrently --names server,docdb,vite --prefix-colors cyan,magenta,yellow \"npm:server\" \"npm:docdb\" \"npm:dev\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "../.venv/bin/duckdb-server",
    "docdb": "../.venv/bin/python docdb_proxy.py",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@uwdata/vgplot": "^0.11.0",
    "htm": "^3.1.1",
    "numcodecs": "^0.3.2",
    "papaparse": "^5.5.3",
    "preact": "^10.29.2",
    "three": "^0.184.0",
    "zarrita": "^0.7.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "happy-dom": "^20.9.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
