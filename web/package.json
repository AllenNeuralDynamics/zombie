{
  "name": "zombie-mosaic",
  "version": "0.1.0",
  "description": "ZOMBIE data explorer — Mosaic/DuckDB-WASM frontend",
  "type": "module",
  "scripts": {
    "start": "concurrently --names server,vite --prefix-colors cyan,yellow \"npm:server\" \"npm:dev\"",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "../.venv/bin/duckdb-server",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .js"
  },
  "dependencies": {
    "@uwdata/vgplot": "^0.11.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.0.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
